---
interface Props {
  page?: "home" | "blog" | "sandbox" | "about";
}
const { page = "home" } = Astro.props;
const withBase = (route = "") => `${import.meta.env.BASE_URL}${route.replace(/^\/+/, "")}`;
const homeHref = withBase();
const blogHref = withBase("blog");
---

<nav class="site-nav">
  <a href={homeHref} class="site-brand">hanifok.com</a>

  <div class="site-nav-right">
    <div class="site-links">
      <a href={homeHref} class:list={["site-link", { "site-link-active": page === "home" }]} data-i18n-key="nav.home">/home</a>
      <a href={blogHref} class:list={["site-link", { "site-link-active": page === "blog" }]} data-i18n-key="nav.blog">/blog</a>
      <a href="#sandbox" class:list={["site-link", { "site-link-active": page === "sandbox" }]} data-i18n-key="nav.sandbox">/sandbox</a>
    </div>

    <div class="locale-switcher" aria-label="language switcher">
      <span class="locale-label" data-i18n-key="nav.localeLabel">lang</span>
      <button type="button" class="locale-btn" data-locale-switch="en">EN</button
      >
      <span class="locale-divider">|</span>
      <button type="button" class="locale-btn" data-locale-switch="id">ID</button
      >
    </div>
  </div>
</nav>
