---
import { HOME_COPY } from "../i18n/home";

const fullSkills = HOME_COPY.en.fullSkills;
---

<section>
  <article class="paper-card tilt-negative">
    <span class="pin-dot" aria-hidden="true"></span>

    <header class="skills-head">
      <h2>
        <span data-i18n-key="fullSkills.title">{fullSkills.title}</span>
        <small data-i18n-key="fullSkills.subtitle">{fullSkills.subtitle}</small>
      </h2>
      <p class="skills-slug" data-i18n-key="fullSkills.slug">{fullSkills.slug}</p>
    </header>

    <div class="skills-groups">
      {
        fullSkills.groups.map((group, groupIndex) => (
          <section class="skills-group">
            <h3 data-i18n-key={`fullSkills.groups.${groupIndex}.title`}>
              {group.title}
            </h3>
            <div class="chip-wrap">
              {group.items.map((item, itemIndex) => (
                <span
                  class="chip"
                  data-i18n-key={`fullSkills.groups.${groupIndex}.items.${itemIndex}`}
                >
                  {item}
                </span>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </article>
</section>

