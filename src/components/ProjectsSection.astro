---
import type { CollectionEntry } from "astro:content";
import { HOME_COPY } from "../i18n/home";

interface Props {
  projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;
const labels = HOME_COPY.en.projects;
const resolveAssetPath = (src?: string) => {
  if (!src) return undefined;
  if (/^(https?:)?\/\//.test(src)) return src;
  return `${import.meta.env.BASE_URL}${src.replace(/^\/+/, "")}`;
};
---

<section>
  <article class="paper-card tilt-positive" data-project-carousel>
    <span class="card-label" data-i18n-key="projects.badge">{labels.badge}</span>
    <span class="pin-dot" aria-hidden="true"></span>

    {
      projects.length > 0 ? (
        <>
          <div class="project-carousel-body">
          <div class="project-stage">
            {projects.map((project, index) => (
              <article
                class={`project-slide ${index === 0 ? "is-active" : ""}`}
                data-project-slide
                data-locale={project.data.lang || 'en'}
              >
                <div class="project-media">
                  {project.data.image ? (
                    <img src={resolveAssetPath(project.data.image)} alt={project.data.title} loading="lazy" />
                  ) : (
                    <div class="project-placeholder" aria-hidden="true"></div>
                  )}
                  <p class="project-year">{project.data.year}</p>
                </div>

                <div class="project-content">
                  <h3>{project.data.title}</h3>
                  <p>
                    {project.data.summary}
                  </p>
                  {project.data.techStack && (
                    <div class="project-tech-stack">
                      {project.data.techStack.map((tech) => (
                        <span class="tech-chip">{tech}</span>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))}
          </div>

          <div class="project-controls">
            <p class="project-count" data-project-count>
              01 / {String(projects.length).padStart(2, "0")}
            </p>

            <div class="project-dots">
              {projects.map((_, index) => (
                <button
                  type="button"
                  class={`project-dot ${index === 0 ? "is-active" : ""}`}
                  data-project-dot={index}
                  aria-label={`Show project ${index + 1}`}
                ></button>
              ))}
            </div>

            <div class="project-arrows">
              <button type="button" class="line-btn square" data-project-prev>
                &larr;
              </button>
              <button type="button" class="line-btn square" data-project-next>
                &rarr;
              </button>
            </div>
          </div>
          </div>
        </>
      ) : (
        <p class="empty-state">Add featured projects in src/content/projects.</p>
      )
    }

  </article>
</section>

<style>
  .project-tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tech-chip {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    background-color: rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.1);
    color: inherit;
    font-weight: 500;
    white-space: nowrap;
  }

  :global(.dark) .tech-chip {
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
</style>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-project-carousel]");
    if (!root) return;

    const count = root.querySelector("[data-project-count]");
    const prev = root.querySelector("[data-project-prev]");
    const next = root.querySelector("[data-project-next]");

    let active = 0;
    let filteredSlides = [];

    const updateAndRender = () => {
      const locale = document.body.dataset.locale || 'en';
      const allSlides = Array.from(root.querySelectorAll("[data-project-slide]"));
      
      // Filter slides by locale
      filteredSlides = allSlides.filter(slide => slide.dataset.locale === locale);
      
      // Hide all slides first, then show only filtered ones
      allSlides.forEach(s => {
        s.style.display = 'none';
        s.classList.remove("is-active");
      });
      
      filteredSlides.forEach(s => s.style.display = '');

      const dots = Array.from(root.querySelectorAll("[data-project-dot]"));
      
      if (filteredSlides.length === 0) {
        if (count) count.textContent = "00 / 00";
        dots.forEach(d => d.style.display = 'none');
        return;
      }

      // Adjust active index if it's out of bounds for the new set
      if (active >= filteredSlides.length) active = 0;

      dots.forEach(d => d.style.display = '');
      
      const render = () => {
        filteredSlides.forEach((slide, index) => {
          slide.classList.toggle("is-active", index === active);
        });

        dots.forEach((dot, index) => {
          dot.classList.toggle("is-active", index === active && index < filteredSlides.length);
          if (index >= filteredSlides.length) dot.style.display = 'none';
        });

        if (count) {
          count.textContent = `${String(active + 1).padStart(2, "0")} / ${String(filteredSlides.length).padStart(2, "0")}`;
        }
      };

      render();
    };

    if (prev) {
      prev.onclick = () => {
        active = active === 0 ? filteredSlides.length - 1 : active - 1;
        updateAndRender();
      };
    }

    if (next) {
      next.onclick = () => {
        active = active === filteredSlides.length - 1 ? 0 : active + 1;
        updateAndRender();
      };
    }

    root.addEventListener("click", (e) => {
      const dot = e.target.closest("[data-project-dot]");
      if (dot) {
        const index = parseInt(dot.getAttribute("data-project-dot"));
        if (index >= 0 && index < filteredSlides.length) {
          active = index;
          updateAndRender();
        }
      }
    });

    document.addEventListener("locale-changed", updateAndRender);
    updateAndRender();
  })();
</script>
