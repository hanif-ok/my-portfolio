---
import { HOME_COPY } from "../i18n/home";

const hero = HOME_COPY.en.hero;
const now = HOME_COPY.en.now;
const portraitSrc = `${import.meta.env.BASE_URL}images/self-portrait.jpg`;
---

<section class="section-two-up">
  <article class="paper-card tilt-negative">
    <span class="card-label" data-i18n-key="hero.badge">{hero.badge}</span>
    <span class="pin-dot" aria-hidden="true"></span>

    <div class="hero-grid">
      <div class="hero-copy">
        <h1 class="hero-heading">
          <span data-i18n-key="hero.introLine1">{hero.introLine1}</span><br />
          <span class="hero-role" data-i18n-key="hero.introLine2" data-roles={JSON.stringify(hero.introLine2)}>{hero.introLine2[0]}</span>
        </h1>
        <div class="hero-lines" aria-hidden="true">
          <span></span>
          <span></span>
        </div>
      </div>

      <div class="hero-avatar-wrap">
        <div class="hero-avatar">
          <img
            class="hero-avatar-image"
            src={portraitSrc}
            alt="Profile portrait"
            loading="eager"
            decoding="async"
          />
        </div>
        <a href="#contact" class="hero-contact" data-i18n-key="hero.contactCta"
          >{hero.contactCta}</a
        >
      </div>
    </div>
  </article>

  <article class="paper-card tilt-positive">
    <span class="card-label" data-i18n-key="now.badge">{now.badge}</span>
    <span class="pin-dot" aria-hidden="true"></span>

    <h2 class="card-title" data-i18n-key="now.title">{now.title}</h2>
    <ul class="bullet-list">
      {
        now.bullets.map((item, index) => (
          <li data-i18n-key={`now.bullets.${index}`}>{item}</li>
        ))
      }
    </ul>
  </article>
</section>

<script>
  const el = document.querySelector<HTMLElement>(".hero-role");
  if (el) {
    let roles: string[] = JSON.parse(el.dataset.roles ?? "[]");
    let idx = 0;
    let timer: ReturnType<typeof setTimeout>;

    const FADE = 350;   // matches CSS transition duration
    const HOLD = 2400;  // how long the word stays visible

    const cycle = () => {
      el.classList.add("is-hidden");
      timer = setTimeout(() => {
        idx = (idx + 1) % roles.length;
        el.textContent = roles[idx];
        el.classList.remove("is-hidden");
        timer = setTimeout(cycle, HOLD + FADE);
      }, FADE);
    };

    el.addEventListener("roles-updated", () => {
      roles = JSON.parse(el.dataset.roles ?? "[]");
      clearTimeout(timer);
      idx = 0;
      el.textContent = roles[0];
      el.classList.remove("is-hidden");
      timer = setTimeout(cycle, HOLD + FADE);
    });

    el.textContent = roles[0];
    timer = setTimeout(cycle, HOLD + FADE);
  }
</script>
